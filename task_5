# 1

USE mydb;

SELECT od.*, (SELECT customer_id FROM orders o WHERE od.order_id = o.id) as customer
FROM order_details od; 

# 2

SELECT od.* 
FROM order_details od
WHERE order_id IN (SELECT id FROM orders WHERE orders.shipper_id =3);

# 3

SELECT temp.id, AVG(temp.quantity) 
FROM (SELECT * FROM order_details WHERE quantity > 10) as temp
GROUP BY temp.id;

# 4

WITH temp1 AS (SELECT * FROM order_details WHERE quantity > 10)
SELECT temp1.id, AVG(temp1.quantity) 
FROM temp1
GROUP BY temp1.id;

# 5

DROP FUNCTION IF EXISTS func1;

DELIMITER //
CREATE FUNCTION func1(num1 FLOAT, num2 FLOAT) 
RETURNS FLOAT
DETERMINISTIC  
NO SQL 
BEGIN 
	DECLARE result FLOAT; 
	SET result = num1 / num2; 
	RETURN result; 
END // 
DELIMITER ;

SELECT *, func1(quantity, 2.0) as half_qty FROM order_details;
